{
  "name": "api_con",
  "version": "4.0.31",
  "description": "API project: api_con",
  "type": "commonjs",
  "main": "lib/main.js",
  "files": [
    "lib/**/*",
    "src/**/*",
    "certs/**/*",
    "scripts/**/*",
    "webpack.config.js",
    "tsconfig.json",
    "main.ts",
    "README.md",
    "package.json",
    ".env.example"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "start": "npm run build:dev && node lib/main.js",
    "start:dev": "concurrently \"npm run build:watch\" \"npm run start:nodemon\"",
    "start:realtime": "concurrently \"npm run build:watch\" \"npm run start:nodemon\" \"npm run watch:logs\"",
    "build:watch": "webpack --mode development --watch",
    "build:watch:verbose": "webpack --mode development --watch --progress --verbose",
    "start:nodemon": "nodemon --watch lib --watch src --ext ts,js,json --exec \"npm run start:server\"",
    "start:server": "node lib/main.js",
    "start:server:debug": "node --inspect lib/main.js",
    "dev": "npm run start:realtime",
    "dev:debug": "concurrently \"npm run build:watch\" \"npm run start:server:debug\"",
    "watch:logs": "tail -f logs/app.log",
    "clean": "rm -rf dist lib",
    "clean:watch": "rm -rf lib && npm run build:dev",
    "test": "echo \"No tests specified\" && exit 0",
    "setup": "./scripts/setup.sh",
    "seed": "npx ts-node src/scripts/seed.ts",
    "seed:force": "npx ts-node src/scripts/seed.ts --force",
    "seed:reset": "npx ts-node src/scripts/seed.ts --reset",
    "seed:truncate": "npx ts-node src/scripts/seed.ts --truncate",
    "setup:permissions": "./scripts/setup-permissions.sh",
    "setup:admin": "npx ts-node src/modules/permission/scripts/setup-admin-permissions.ts",
    "setup:admin-user": "npx ts-node src/modules/user/scripts/setup-admin-user.ts",
    "test:permissions": "npx ts-node src/modules/user/scripts/test-permissions.ts",
    "generate:module": "./scripts/generate-module.sh",
    "generate:endpoint": "./scripts/generate-endpoint.sh",
    "generate:table": "npx ts-node src/scripts/generate-table.ts",
    "generate:relation": "npx ts-node src/scripts/generate-relation.ts",
    "extend:feature": "npx ts-node src/scripts/extend-feature.ts",
    "process:template": "./scripts/process-template.sh",
    "cli": "./scripts/cli-commands.sh",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "docs": "npm run build:dev && npx typedoc src/**/*.ts --out docs",
    "docs:serve": "npx http-server docs -p 8080",
    "docker:build": "docker build -t diagramers-api .",
    "docker:run": "docker run -p 4000:4000 diagramers-api",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "backup": "npx ts-node src/scripts/backup.ts",
    "backup:restore": "npx ts-node src/scripts/backup.ts --restore",
    "migrate": "npx ts-node src/scripts/migrate.ts",
    "migrate:create": "npx ts-node src/scripts/migrate.ts --create",
    "migrate:rollback": "npx ts-node src/scripts/migrate.ts --rollback",
    "health": "curl -f http://localhost:4000/health || echo 'Server not running'",
    "logs": "tail -f logs/app.log",
    "logs:clear": "> logs/app.log",
    "env:debug": "node scripts/env-debug.js",
    "env:validate": "node scripts/env-debug.js --validate",
    "env:check": "node scripts/env-debug.js --check-files",
    "monitor": "npx ts-node src/scripts/monitor.ts",
    "deploy": "./scripts/deploy.sh",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.13",
    "@types/jsonwebtoken": "^9.0.10",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.3.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.17.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "nodemailer-express-handlebars": "^6.1.2",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "twilio": "^4.23.0",
    "uuid": "^9.0.1",
    "vm2": "^3.9.19",
    "xmlrpc": "^1.3.2"
  },
  "devDependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "base-64": "^1.0.0",
    "bson": "^6.6.0",
    "concurrently": "^8.2.2",
    "express": "^4.19.2",
    "express-http-to-https": "^1.1.4",
    "firebase": "^10.11.0",
    "firebase-functions-test": "^3.2.0",
    "mini-css-extract-plugin": "^2.8.1",
    "moment-timezone": "^0.5.45",
    "mongoose": "^8.16.3",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.10",
    "prettier": "3.8.1",
    "socket.io": "^4.7.5",
    "sortablejs": "^1.15.2",
    "typescript": "^5.4.5",
    "uuid4": "^2.0.3",
    "vm2": "^3.9.19",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0",
    "yup": "^1.4.0"
  },
  "keywords": [
    "diagramers",
    "api",
    "nodejs",
    "typescript",
    "firebase",
    "express",
    "socket.io",
    "template"
  ],
  "author": "Diagramers Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diagramers/diagramers-api.git"
  },
  "bugs": {
    "url": "https://github.com/diagramers/diagramers-api/issues"
  },
  "homepage": "https://github.com/diagramers/diagramers-api#readme"
}
