# =============================================================================
# SENDIFIER API - ENVIRONMENT CONFIGURATION
# =============================================================================

# Application environment
NODE_ENV=

# Server configuration
PORT=
HOST=

# Application URL
APP_URL=
# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB configuration
DATABASE_TYPE=
DATABASE_URL=
DATABASE_NAME=

# MongoDB specific settings
MONGODB_USE_NEW_URL_PARSER=
MONGODB_USE_UNIFIED_TOPOLOGY=
MONGODB_RETRY_WRITES=
MONGODB_W=
MONGODB_READ_PREFERENCE=
MONGODB_MAX_POOL_SIZE=
MONGODB_MIN_POOL_SIZE=
MONGODB_MAX_IDLE_TIME_MS=
MONGODB_SERVER_SELECTION_TIMEOUT_MS=
MONGODB_SOCKET_TIMEOUT_MS=
MONGODB_CONNECT_TIMEOUT_MS=

# =============================================================================
# AUTHENTICATION & AUTHORIZATION
# =============================================================================

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=
REFRESH_TOKEN_EXPIRES_IN=

# Auth settings
AUTH_DEFAULT_PROVIDER=
AUTH_INTERNAL_ENABLED=
AUTH_INTERNAL_ALLOW_REGISTRATION=
AUTH_INTERNAL_REQUIRE_EMAIL_VERIFICATION=

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================

# Email service
EMAIL_ENABLED=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_REPLY_TO=

# SMTP Configuration (Hostinger)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=

# Alternative SMTP settings
AUTH_EMAIL_NODEMAILER_HOST=
AUTH_EMAIL_NODEMAILER_PORT=
AUTH_EMAIL_NODEMAILER_SECURE=
AUTH_EMAIL_NODEMAILER_USER=
AUTH_EMAIL_NODEMAILER_PASS=

# =============================================================================
# SECURITY & CORS
# =============================================================================

# CORS settings
CORS_ORIGIN=
CORS_CREDENTIALS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log level
LOG_LEVEL=
LOG_FORMAT=

# Debug mode
DEBUG=
DEBUG_AUTH=

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# API documentation
API_DOCS_ENABLED=
API_DOCS_PATH=

# Development tools
DEV_TOOLS_ENABLED=
HOT_RELOAD_ENABLED=

# =============================================================================
# SOCKET.IO CONFIGURATION
# =============================================================================

# Socket.IO
SOCKET_ENABLED=
SOCKET_PORT=
SOCKET_CORS_ORIGIN=

# =============================================================================
# OTP CONFIGURATION
# =============================================================================

# OTP settings
OTP_LENGTH=
OTP_TYPE=
OTP_EXPIRY_MINUTES=
OTP_MAX_ATTEMPTS=
OTP_EXCLUDE_SIMILAR=
OTP_EXCLUDE_AMBIGUOUS=

# =============================================================================
# IMPORTANT: UPDATE THESE VALUES WITH YOUR ACTUAL CREDENTIALS
# =============================================================================

# Update these with your actual Hostinger email credentials:
# SMTP_USER=your-actual-email@sendifier.com
# SMTP_PASS=your-actual-email-password

# Update these with your actual WhatsApp Business API credentials:
# WHATSAPP_BUSINESS_API_PHONE_NUMBER_ID=your_actual_phone_number_id
# WHATSAPP_BUSINESS_API_BUSINESS_ACCOUNT_ID=your_actual_business_account_id
# WHATSAPP_BUSINESS_API_TOKEN=your_actual_token

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================

# Database seeding
DB_SEED=
DB_SEED_FORCE=
DB_SEED_TRUNCATE=

# Logging database
LOG_DATABASE_ENABLED=
LOG_DATABASE_COLLECTION=
LOG_DATABASE_TTL_DAYS=

# Logging file
LOG_FILE_ENABLED=
LOG_FILE_PATH=
LOG_FILE_MAX_SIZE=
LOG_FILE_MAX_FILES=

# Logging colors
LOG_COLORS=

# External logging
LOG_EXTERNAL_ENABLED=
LOG_EXTERNAL_TYPE=
LOG_EXTERNAL_URL=
LOG_EXTERNAL_API_KEY=

# =============================================================================
# SERVER & CORS CONFIGURATION
# =============================================================================

# Server settings
HELMET_ENABLED=
COMPRESSION_ENABLED=

# Rate limiting
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=

# Health check
HEALTH_CHECK_ENABLED=
HEALTH_CHECK_PATH=/

# Metrics
METRICS_ENABLED=

