# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Firebase Service Account - Choose one method:
# Method 1: File path (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Method 2: Environment-specific paths (dev/prod)
# FIREBASE_SERVICE_ACCOUNT_PATH_DEV=certs/firebase-service-account-dev.json
# FIREBASE_SERVICE_ACCOUNT_PATH_PROD=certs/firebase-service-account-prod.json

# Method 3: JSON string (for containerized deployments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase Storage Configuration
FIREBASE_STORAGE_BUCKET=
# FIREBASE_STORAGE_BUCKET_DEV=sendifier-dev.appspot.com
# FIREBASE_STORAGE_BUCKET_PROD=sendifier-prod.appspot.com

# Storage Provider Configuration
STORAGE_DEFAULT_PROVIDER=
# STORAGE_DEFAULT_PROVIDER=firebase

#IslamHouse API Base URL
ISLAMHOUSE_API_BASE_URL=