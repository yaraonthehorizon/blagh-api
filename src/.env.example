# =============================================================================
# SENDIFIER API - ENVIRONMENT CONFIGURATION
# =============================================================================

# Application environment
NODE_ENV=development

# Server configuration
PORT=4000
HOST=0.0.0.0

# Application URL
APP_URL=http://app_URL
# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB configuration
DATABASE_TYPE=mongodb
DATABASE_URL=mongodb://localhost:27017/ibalagh_api-development
DATABASE_NAME=ibalagh_api-development

# MongoDB specific settings
MONGODB_USE_NEW_URL_PARSER=true
MONGODB_USE_UNIFIED_TOPOLOGY=true
MONGODB_RETRY_WRITES=true
MONGODB_W=majority
MONGODB_READ_PREFERENCE=primary
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_MAX_IDLE_TIME_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000

# =============================================================================
# AUTHENTICATION & AUTHORIZATION
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Auth settings
AUTH_DEFAULT_PROVIDER=internal
AUTH_INTERNAL_ENABLED=true
AUTH_INTERNAL_ALLOW_REGISTRATION=true
AUTH_INTERNAL_REQUIRE_EMAIL_VERIFICATION=true

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================

# Email service
EMAIL_ENABLED=true
EMAIL_PROVIDER=nodemailer
EMAIL_FROM=noreply@sendifier.com
EMAIL_REPLY_TO=support@sendifier.com

# SMTP Configuration (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Alternative SMTP settings
AUTH_EMAIL_NODEMAILER_HOST=smtp.hostinger.com
AUTH_EMAIL_NODEMAILER_PORT=587
AUTH_EMAIL_NODEMAILER_SECURE=false
AUTH_EMAIL_NODEMAILER_USER=your-email@domain.com
AUTH_EMAIL_NODEMAILER_PASS=your-email-password

# =============================================================================
# SECURITY & CORS
# =============================================================================

# CORS settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:19006
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log level
LOG_LEVEL=info
LOG_FORMAT=colored

# Debug mode
DEBUG=false
DEBUG_AUTH=false

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# API documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api-docs

# Development tools
DEV_TOOLS_ENABLED=true
HOT_RELOAD_ENABLED=true

# =============================================================================
# SOCKET.IO CONFIGURATION
# =============================================================================

# Socket.IO
SOCKET_ENABLED=true
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=http:/frontend-url

# =============================================================================
# OTP CONFIGURATION
# =============================================================================

# OTP settings
OTP_LENGTH=4
OTP_TYPE=numeric
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_EXCLUDE_SIMILAR=false
OTP_EXCLUDE_AMBIGUOUS=false

# =============================================================================
# IMPORTANT: UPDATE THESE VALUES WITH YOUR ACTUAL CREDENTIALS
# =============================================================================

# Update these with your actual Hostinger email credentials:
# SMTP_USER=your-actual-email@sendifier.com
# SMTP_PASS=your-actual-email-password

# Update these with your actual WhatsApp Business API credentials:
# WHATSAPP_BUSINESS_API_PHONE_NUMBER_ID=your_actual_phone_number_id
# WHATSAPP_BUSINESS_API_BUSINESS_ACCOUNT_ID=your_actual_business_account_id
# WHATSAPP_BUSINESS_API_TOKEN=your_actual_token

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================

# Database seeding
DB_SEED=false
DB_SEED_FORCE=false
DB_SEED_TRUNCATE=false

# Logging database
LOG_DATABASE_ENABLED=false
LOG_DATABASE_COLLECTION=logs
LOG_DATABASE_TTL_DAYS=30

# Logging file
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5

# Logging colors
LOG_COLORS=true

# External logging
LOG_EXTERNAL_ENABLED=false
LOG_EXTERNAL_TYPE=serilog
LOG_EXTERNAL_URL=
LOG_EXTERNAL_API_KEY=

# =============================================================================
# SERVER & CORS CONFIGURATION
# =============================================================================

# Server settings
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Metrics
METRICS_ENABLED=false

# =============================================================================
# CURRENT STATUS
# =============================================================================

# This .env file has been restored with all necessary WhatsApp and other
# environment variables. Please update the following with your actual values:

# 1. SMTP credentials (Hostinger email)
# 2. WhatsApp Business API credentials
# 3. JWT_SECRET (change from default)
# 4. Database URL if different from localhost

# File created: Tue Aug 26 15:07:42 EEST 2025
# Total configuration sections: 12+
WHATSAPP_BUSINESS_API_PHONE_NUMBER=+1234567890
FACEBOOK_MESSENGER_REDIRECT_URI=https://api-tunnel.sendifier.com/facebook-callback
cors=true

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Firebase Service Account - Choose one method:
# Method 1: File path (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=certs/firebase-service-account.json

# Method 2: Environment-specific paths (dev/prod)
# FIREBASE_SERVICE_ACCOUNT_PATH_DEV=certs/firebase-service-account-dev.json
# FIREBASE_SERVICE_ACCOUNT_PATH_PROD=certs/firebase-service-account-prod.json

# Method 3: JSON string (for containerized deployments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase Storage Configuration
FIREBASE_STORAGE_BUCKET=sendifier-dev.appspot.com
# FIREBASE_STORAGE_BUCKET_DEV=sendifier-dev.appspot.com
# FIREBASE_STORAGE_BUCKET_PROD=sendifier-prod.appspot.com

# Storage Provider Configuration
STORAGE_DEFAULT_PROVIDER=firebase
# STORAGE_DEFAULT_PROVIDER=firebase
